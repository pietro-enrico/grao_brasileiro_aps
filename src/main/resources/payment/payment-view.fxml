<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #FFFFFFFF;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="payment.PaymentController">

    <!-- ===== NAVBAR ===== -->
    <ImageView fitHeight="67.0" fitWidth="71.0" layoutX="90.0" layoutY="18.0" pickOnBounds="true" preserveRatio="true">
        <image><Image url="@../assets/coffee-beans.png" /></image>
    </ImageView>
    <Label layoutX="168.0" layoutY="38.0" text="Grão Brasileiro" textFill="#1a3a23">
        <font><Font name="Georgia" size="32.0" /></font>
    </Label>

    <Label fx:id="id_donate" layoutX="580.0" layoutY="52.0" onMouseClicked="#redirectToDonate" text="Doação" textFill="#1a3a23">
        <font><Font name="Georgia" size="18.0" /></font>
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </Label>
    <Label fx:id="id_about" layoutX="700.0" layoutY="52.0" onMouseClicked="#redirectToAbout" text="Sobre" textFill="#1a3a23">
        <font><Font name="Georgia" size="18.0" /></font>
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </Label>
    <Label fx:id="id_collaborators" layoutX="800.0" layoutY="52.0" onMouseClicked="#redirectToCollaborators" text="Colaboradores" textFill="#1a3a23">
        <font><Font name="Georgia" size="18.0" /></font>
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </Label>
    <Label fx:id="id_my_donates" layoutX="980.0" layoutY="52.0" onMouseClicked="#redirectToMyDonates" text="Minhas Doações" textFill="#1a3a23">
        <font><Font name="Georgia" size="18.0" /></font>
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </Label>

    <!-- linha separadora -->
    <Rectangle fill="#D4B896" height="1.5" layoutX="0.0" layoutY="98.0" width="1280.0" />

    <!-- ===== BANNER VERDE ===== -->
    <Rectangle fill="#2C5031" height="80.0" layoutX="0.0" layoutY="100.0" width="1280.0" />

    <Label layoutX="90.0" layoutY="112.0" text="Realizar Doação" textFill="#F5DEB8">
        <font><Font name="System Bold" size="22.0" /></font>
    </Label>
    <Label layoutX="90.0" layoutY="144.0" text="Preencha os campos abaixo e escolha como deseja contribuir." textFill="#A8C8A0">
        <font><Font size="13.0" /></font>
    </Label>

    <!-- steps indicadores -->
    <!-- step 1 -->
    <Rectangle arcHeight="26" arcWidth="26" fill="#F5DEB8" height="26.0" layoutX="820.0" layoutY="118.0" width="26.0" />
    <Label layoutX="828.0" layoutY="122.0" text="1" textFill="#2C5031">
        <font><Font name="System Bold" size="12.0" /></font>
    </Label>
    <Label layoutX="852.0" layoutY="124.0" text="O que doar" textFill="#F5DEB8">
        <font><Font name="System Bold" size="12.0" /></font>
    </Label>

    <Rectangle fill="rgba(255,255,255,0.25)" height="2.0" layoutX="940.0" layoutY="130.0" width="40.0" />

    <!-- step 2 -->
    <Rectangle arcHeight="26" arcWidth="26" fill="#F5DEB8" height="26.0" layoutX="986.0" layoutY="118.0" width="26.0" />
    <Label layoutX="994.0" layoutY="122.0" text="2" textFill="#2C5031">
        <font><Font name="System Bold" size="12.0" /></font>
    </Label>
    <Label layoutX="1018.0" layoutY="124.0" text="Pagamento" textFill="#F5DEB8">
        <font><Font name="System Bold" size="12.0" /></font>
    </Label>

    <Rectangle fill="rgba(255,255,255,0.25)" height="2.0" layoutX="1100.0" layoutY="130.0" width="40.0" />

    <!-- step 3 -->
    <Rectangle arcHeight="26" arcWidth="26" fill="rgba(255,255,255,0.18)" height="26.0" layoutX="1146.0" layoutY="118.0" width="26.0" />
    <Label layoutX="1154.0" layoutY="122.0" text="3" textFill="#A8C8A0">
        <font><Font name="System Bold" size="12.0" /></font>
    </Label>
    <Label layoutX="1178.0" layoutY="124.0" text="Confirmação" textFill="#A8C8A0">
        <font><Font size="12.0" /></font>
    </Label>

    <!-- ===== CARD ESQUERDO — O QUE DOAR ===== -->
    <Rectangle arcHeight="14" arcWidth="14" fill="#FDF6EC" height="460.0" layoutX="70.0" layoutY="200.0" width="520.0" />
    <Rectangle arcHeight="14" arcWidth="14" fill="transparent" height="460.0" layoutX="70.0" layoutY="200.0" stroke="#D4B896" strokeWidth="1.0" width="520.0" />

    <!-- título card -->
    <Rectangle arcHeight="24" arcWidth="24" fill="#2C5031" height="24.0" layoutX="90.0" layoutY="218.0" width="24.0" />
    <Label layoutX="97.0" layoutY="222.0" text="1" textFill="#A8C8A0">
        <font><Font name="System Bold" size="11.0" /></font>
    </Label>
    <Label layoutX="124.0" layoutY="220.0" text="O QUE DESEJA DOAR?" textFill="#7A5030">
        <font><Font name="System Bold" size="11.0" /></font>
    </Label>

    <!-- categoria -->
    <Label layoutX="90.0" layoutY="258.0" text="Categoria" textFill="#1a3a23">
        <font><Font name="System Bold" size="13.0" /></font>
    </Label>
    <ComboBox fx:id="categoria" layoutX="90.0" layoutY="278.0" prefHeight="38.0" prefWidth="460.0" style="-fx-background-color: #ffffff; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </ComboBox>

    <!-- suprimento -->
    <Label fx:id="lblSuprimento" layoutX="90.0" layoutY="334.0" text="Tipo de suprimento" textFill="#1a3a23" visible="false">
        <font><Font name="System Bold" size="13.0" /></font>
    </Label>
    <ComboBox fx:id="sub_categoria" layoutX="90.0" layoutY="354.0" prefHeight="38.0" prefWidth="460.0" style="-fx-background-color: #ffffff; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" visible="false">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </ComboBox>

    <!-- quantidade -->
    <Label fx:id="lblQuantidade" layoutX="90.0" layoutY="410.0" text="Quantidade" textFill="#1a3a23" visible="false">
        <font><Font name="System Bold" size="13.0" /></font>
    </Label>
    <TextField fx:id="quantidade" layoutX="90.0" layoutY="430.0" prefHeight="38.0" prefWidth="460.0" promptText="Ex: 10 (apenas números)" style="-fx-background-color: #ffffff; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" visible="false" />

    <!-- valor (dinheiro) -->
    <Label fx:id="lblValor" layoutX="90.0" layoutY="334.0" text="Valor (R$)" textFill="#1a3a23" visible="false">
        <font><Font name="System Bold" size="13.0" /></font>
    </Label>
    <TextField fx:id="value" layoutX="90.0" layoutY="354.0" prefHeight="38.0" prefWidth="460.0" promptText="R$ 0,00" style="-fx-background-color: #ffffff; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 13px;" visible="false" />

    <!-- ===== CARD DIREITO — PAGAMENTO ===== -->
    <Rectangle arcHeight="14" arcWidth="14" fill="#FDF6EC" height="460.0" layoutX="620.0" layoutY="200.0" width="590.0" />
    <Rectangle arcHeight="14" arcWidth="14" fill="transparent" height="460.0" layoutX="620.0" layoutY="200.0" stroke="#D4B896" strokeWidth="1.0" width="590.0" />

    <!-- título card -->
    <Rectangle arcHeight="24" arcWidth="24" fill="#2C5031" height="24.0" layoutX="640.0" layoutY="218.0" width="24.0" />
    <Label layoutX="647.0" layoutY="222.0" text="2" textFill="#A8C8A0">
        <font><Font name="System Bold" size="11.0" /></font>
    </Label>
    <Label layoutX="674.0" layoutY="220.0" text="FORMA DE PAGAMENTO" textFill="#7A5030">
        <font><Font name="System Bold" size="11.0" /></font>
    </Label>

    <!-- botões de pagamento -->
    <ToggleButton fx:id="btnPix" layoutX="640.0" layoutY="258.0" prefHeight="42.0" prefWidth="170.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a23; -fx-background-radius: 8; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 14px; -fx-font-weight: bold;" text="🔲  Pix" visible="false">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </ToggleButton>
    <ToggleButton fx:id="btnCC" layoutX="826.0" layoutY="258.0" prefHeight="42.0" prefWidth="186.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a23; -fx-background-radius: 8; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 14px; -fx-font-weight: bold;" text="💳  Cartão de Crédito" visible="false">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </ToggleButton>
    <ToggleButton fx:id="btnPayPal" layoutX="1028.0" layoutY="258.0" prefHeight="42.0" prefWidth="162.0" style="-fx-background-color: #ffffff; -fx-text-fill: #1a3a23; -fx-background-radius: 8; -fx-border-color: #D4B896; -fx-border-radius: 8; -fx-border-width: 1.5; -fx-font-size: 14px; -fx-font-weight: bold;" text="🅿️  PayPal" visible="false">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </ToggleButton>
    <ToggleButton fx:id="btnCorreios" layoutX="640.0" layoutY="258.0" prefHeight="42.0" prefWidth="550.0" style="-fx-background-color: #FFF8E1; -fx-text-fill: #5D4037; -fx-background-radius: 8; -fx-border-color: #C8A830; -fx-border-radius: 8; -fx-border-width: 2; -fx-font-size: 14px; -fx-font-weight: bold;" text="📦  Enviar pelos Correios" visible="false">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </ToggleButton>

    <!-- botão confirmar -->
    <Button fx:id="btnConfirmar" layoutX="640.0" layoutY="316.0" onAction="#confirmarDoacao" prefHeight="46.0" prefWidth="550.0" style="-fx-background-color: #2C5031; -fx-text-fill: #F5DEB8; -fx-background-radius: 8; -fx-border-color: none; -fx-font-size: 15px; -fx-font-weight: bold;" text="Confirmar Doação">
        <cursor><Cursor fx:constant="HAND" /></cursor>
    </Button>

    <!-- QR Code (Pix) -->
    <Pane fx:id="qrCodeBox" layoutX="640.0" layoutY="378.0" prefHeight="268.0" prefWidth="550.0" style="-fx-background-color: #3A2A1A; -fx-background-radius: 12;" visible="false">
        <Label fx:id="lblValorDoado" layoutX="175.0" layoutY="14.0" style="-fx-text-fill: #F5DEB8; -fx-font-weight: bold; -fx-font-size: 14px; -fx-text-alignment: center;" text="VALOR DOADO:&#10;R$ 0,00" />
        <ImageView fx:id="qrImageView" fitHeight="150.0" fitWidth="150.0" layoutX="200.0" layoutY="55.0" />
        <Label fx:id="lblCodigoPix" layoutX="30.0" layoutY="220.0" prefWidth="490.0" style="-fx-text-fill: #A8C8A0; -fx-font-size: 11px;" text="Código PIX aqui" wrapText="true" />
    </Pane>

    <!-- Correios -->
    <Pane fx:id="correiosBox" layoutX="640.0" layoutY="378.0" prefHeight="268.0" prefWidth="550.0" style="-fx-background-color: #FFF8E1; -fx-background-radius: 12; -fx-border-color: #C8A830; -fx-border-width: 2; -fx-border-radius: 12;" visible="false">
        <Label layoutX="140.0" layoutY="14.0" style="-fx-text-fill: #5D4037; -fx-font-weight: bold; -fx-font-size: 16px;" text="📦 SELO DE POSTAGEM" />
        <Label layoutX="30.0" layoutY="56.0" style="-fx-text-fill: #5D4037; -fx-font-weight: bold; -fx-font-size: 12px;" text="Código de rastreio:" />
        <Label fx:id="lblCodigoCorreios" layoutX="30.0" layoutY="76.0" style="-fx-text-fill: #1a3a23; -fx-font-family: 'Consolas'; -fx-font-weight: bold; -fx-font-size: 22px;" text="—" />
        <Label layoutX="30.0" layoutY="118.0" style="-fx-text-fill: #5D4037; -fx-font-weight: bold; -fx-font-size: 12px;" text="Destinatário:" />
        <Label layoutX="30.0" layoutY="138.0" prefWidth="490.0" style="-fx-text-fill: #4A3020; -fx-font-size: 12px;" text="Grão Brasileiro — Centro de Doações&#10;Rua das Flores, 123 — São Paulo/SP — CEP 01234-567" wrapText="true" />
        <Button fx:id="btnBaixarSelo" layoutX="165.0" layoutY="210.0" onAction="#baixarSeloCorreios" prefHeight="38.0" prefWidth="220.0" style="-fx-background-color: #FFFFFFFF; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-border-color: none;" text="⬇  Baixar selo (.txt)">
            <cursor><Cursor fx:constant="HAND" /></cursor>
        </Button>
    </Pane>

</Pane>
