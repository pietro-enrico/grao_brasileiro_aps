<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="720.0" prefWidth="1300.0" style="-fx-background-color: #F2F2F2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="payment.PaymentController">
    <ImageView fitHeight="67.0" fitWidth="71.0" layoutX="104.0" layoutY="62.0" pickOnBounds="true" preserveRatio="true">
        <image>
            <Image url="@../assets/coffee-beans.png" />
        </image>
    </ImageView>
    <Label layoutX="170.0" layoutY="83.0" style="-fx-font-family: 'Georgia'; -fx-font-size: 38px; -fx-text-fill: #1B3A1B;" text="Grão Brasileiro" textFill="#1a3a23" />

    <!-- MENU -->
    <Label fx:id="id_donate" layoutX="589.0" layoutY="95.0" onMouseClicked="#redirectToDonate" style="-fx-font-family: 'Georgia'; -fx-font-size: 25px; -fx-text-fill: #1B3A1B;" text="Doação" textFill="#1a3a23">
      <font>
         <Font size="18.0" />
      </font>
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></Label>
    <Label fx:id="id_about" layoutX="709.0" layoutY="95.0" onMouseClicked="#redirectToAbout" style="-fx-font-family: 'Georgia'; -fx-font-size: 25px; -fx-text-fill: #1B3A1B;" text="Sobre" textFill="#1a3a23">
      <font>
         <Font size="15.0" />
      </font>
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></Label>
    <Label fx:id="id_collaborators" layoutX="809.0" layoutY="95.0" onMouseClicked="#redirectToCollaborators" style="-fx-font-family: 'Georgia'; -fx-font-size: 25px; -fx-text-fill: #1B3A1B;" text="Colaboradores" textFill="#1a3a23">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></Label>
    <Label fx:id="id_my_donates" layoutX="999.0" layoutY="95.0" onMouseClicked="#redirectToMyDonates" style="-fx-font-family: 'Georgia'; -fx-font-size: 25px; -fx-text-fill: #1B3A1B;" text="Minhas Doações" textFill="#1a3a23">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></Label>

    <!-- COLUNA ESQUERDA -->
    <Label layoutX="150.0" layoutY="220.0" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#333;" text="O que deseja doar?" />
    <ComboBox fx:id="categoria" layoutX="150.0" layoutY="250.0" prefHeight="35.0" prefWidth="330.0" style="-fx-background-color:#D9E8D4; -fx-background-radius:4;">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></ComboBox>

    <Label fx:id="lblSuprimento" layoutX="150.0" layoutY="310.0" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#333;" text="Qual tipo de suprimento?" visible="false" />
    <ComboBox fx:id="sub_categoria" layoutX="150.0" layoutY="340.0" prefHeight="35.0" prefWidth="330.0" style="-fx-background-color:#D9E8D4; -fx-background-radius:4;" visible="false">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></ComboBox>

    <Label fx:id="lblQuantidade" layoutX="150.0" layoutY="400.0" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#333;" text="Quantidade?" visible="false" />
    <TextField fx:id="quantidade" layoutX="150.0" layoutY="430.0" prefHeight="35.0" prefWidth="330.0" promptText="Escreva a quantidade com número apenas (sem Kg ou L)" style="-fx-background-color:#D9E8D4; -fx-background-radius:4;" visible="false" />

    <Label fx:id="lblValor" layoutX="150.0" layoutY="300.0" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#333;" text="Valor:" visible="false" />
    <TextField fx:id="value" layoutX="150.0" layoutY="330.0" prefHeight="35.0" prefWidth="330.0" promptText="R$ 0,00" style="-fx-background-color:#D9E8D4; -fx-background-radius:4;" visible="false" />

    <!-- COLUNA DIREITA -->
    <Label layoutX="650.0" layoutY="220.0" style="-fx-font-size:17px; -fx-font-weight:bold; -fx-text-fill:#333;" text="Selecione a Forma de Pagamento:" />

    <ToggleButton fx:id="btnPix" layoutX="650.0" layoutY="250.0" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color:#D9E8D4; -fx-text-fill:#333; -fx-background-radius:4; -fx-font-size:14px;" text="Pix" visible="false">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></ToggleButton>
    <ToggleButton fx:id="btnCC" layoutX="820.0" layoutY="250.0" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color:#D9E8D4; -fx-text-fill:#333; -fx-background-radius:4; -fx-font-size:14px;" text="Cartão de crédito" visible="false">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></ToggleButton>
    <ToggleButton fx:id="btnPayPal" layoutX="1030.0" layoutY="250.0" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color:#D9E8D4; -fx-text-fill:#333; -fx-background-radius:4; -fx-font-size:14px;" text="PayPal" visible="false">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></ToggleButton>
    <ToggleButton fx:id="btnCorreios" layoutX="650.0" layoutY="250.0" prefHeight="40.0" prefWidth="520.0" style="-fx-background-color:#FFE082; -fx-text-fill:#5D4037; -fx-background-radius:4; -fx-font-size:14px; -fx-font-weight:bold;" text="📦 Correios" visible="false">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></ToggleButton>

    <Button fx:id="btnConfirmar" layoutX="650.0" layoutY="320.0" onAction="#confirmarDoacao" prefHeight="45.0" prefWidth="520.0" style="-fx-background-color:#3B2A1A; -fx-text-fill:white; -fx-background-radius:4; -fx-font-size:16px;" text="Confirmar">
      <cursor>
         <Cursor fx:constant="HAND" />
      </cursor></Button>

    <!-- QR CODE -->
    <Pane fx:id="qrCodeBox" layoutX="650.0" layoutY="390.0" prefHeight="290.0" prefWidth="520.0" style="-fx-background-color:#3B2A1A; -fx-background-radius:8;" visible="false">
        <Label fx:id="lblValorDoado" layoutX="200.0" layoutY="15.0" style="-fx-text-fill:white; -fx-font-weight:bold; -fx-font-size:14px; -fx-text-alignment:center;" text="VALOR DOADO:&#10;R$ 0,00" />
        <ImageView fx:id="qrImageView" fitHeight="160.0" fitWidth="160.0" layoutX="180.0" layoutY="60.0" />
        <Label fx:id="lblCodigoPix" layoutX="40.0" layoutY="235.0" prefWidth="440.0" style="-fx-text-fill:white; -fx-font-size:11px;" text="Código PIX" wrapText="true" />
    </Pane>

    <!-- CORREIOS -->
    <Pane fx:id="correiosBox" layoutX="650.0" layoutY="390.0" prefHeight="290.0" prefWidth="520.0" style="-fx-background-color:#FFF8E1; -fx-background-radius:8; -fx-border-color:#5D4037; -fx-border-width:2; -fx-border-radius:8;" visible="false">
        <Label layoutX="155.0" layoutY="15.0" style="-fx-text-fill:#5D4037; -fx-font-weight:bold; -fx-font-size:18px;" text="📦 SELO DE POSTAGEM" />
        <Label layoutX="40.0" layoutY="60.0" style="-fx-text-fill:#5D4037; -fx-font-weight:bold; -fx-font-size:13px;" text="Código de rastreio:" />
        <Label fx:id="lblCodigoCorreios" layoutX="40.0" layoutY="80.0" style="-fx-text-fill:#000; -fx-font-family:'Consolas'; -fx-font-weight:bold; -fx-font-size:22px;" text="—" />
        <Label layoutX="40.0" layoutY="125.0" style="-fx-text-fill:#5D4037; -fx-font-weight:bold; -fx-font-size:13px;" text="Destinatário:" />
        <Label layoutX="40.0" layoutY="145.0" style="-fx-text-fill:#333; -fx-font-size:12px;" text="Grão Brasileiro - Centro de Doações&#10;Rua das Flores, 123 - São Paulo/SP - CEP 01234-567" />
        <Button fx:id="btnBaixarSelo" layoutX="150.0" layoutY="220.0" onAction="#baixarSeloCorreios" prefHeight="38.0" prefWidth="220.0" style="-fx-background-color:#5D4037; -fx-text-fill:white; -fx-background-radius:4; -fx-font-weight:bold;" text="⬇  Baixar selo (.txt)">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor></Button>
    </Pane>

</Pane>
